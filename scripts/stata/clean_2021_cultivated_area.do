/*============================================================
  clean_2021_cultivated_area.do
  ------------------------------------------------------------
  Cleans the 2021 Korean cultivated/arable land area survey.

  Source : data/temp/2021_cultivated_area_utf8.csv
           (UTF-8 version of the original EUC-KR CSV;
            generated by: python3 scripts/python/encode_convert.py)
  Output : data/clean/2021_cultivated_area_clean.dta

  Run from project root:
      stata -b do scripts/stata/clean_2021_cultivated_area.do

  INVENTORY
  ---------
  N = 153 rows, K = 11 columns
  Identifiers: 조사연도 (survey year, uniformly 2021)
               행정구역시도코드 (province/metro code, 17 unique values)
  Area variables: paddy/non-paddy/total × cultivated/idle/arable
  WARNING: 9 rows per region code — no sub-identifier present in source.
           (survey_year, region_code) does NOT uniquely identify obs.
============================================================*/

version 17
clear all
set more off

* ── WORKING DIRECTORY ────────────────────────────────────────────────────────
* Set this to your project root before running.
* All paths in this script are relative to this directory.
cd "/Users/tchoi/my-project"

* PREREQUISITE: convert the EUC-KR source CSV to UTF-8 first:
*   shell python3 scripts/python/encode_convert.py

* ── LOG ──────────────────────────────────────────────────────────────────────
capture mkdir "quality_reports"
log using "quality_reports/clean_2021_cultivated_area.log", replace text

di "Script: clean_2021_cultivated_area.do"
di "Date  : $S_DATE $S_TIME"

* ── 1. LOAD ──────────────────────────────────────────────────────────────────
* Source CSV is originally EUC-KR encoded. Import from the UTF-8 copy in
* data/temp/ (generate with: python3 scripts/python/encode_convert.py).
import delimited "data/temp/2021_cultivated_area_utf8.csv", ///
    encoding(utf-8) varnames(1) clear

di "Loaded: `=_N' obs × `=c(k)' vars"

* ── 2. RENAME VARIABLES ──────────────────────────────────────────────────────
* Korean → English names. Original Korean kept in variable labels below.
rename 조사연도             survey_year
rename 행정구역시도코드      region_code
rename 논_금년경지합계면적   paddy_cultivated_area
rename 밭_금년경지합계면적   nonpaddy_cultivated_area
rename 계_금년경지합계면적   total_cultivated_area
rename 논_규반합계면적       paddy_idle_area
rename 밭_규반합계면적       nonpaddy_idle_area
rename 계_규반합계면적       total_idle_area
rename 논_가경합계면적       paddy_arable_area
rename 밭_가경합계면적       nonpaddy_arable_area
rename 계_가경합계면적       total_arable_area

* ── 3. LABEL VARIABLES ───────────────────────────────────────────────────────
label variable survey_year             "Survey year (조사연도)"
label variable region_code             "Province/metro code (행정구역시도코드)"
label variable paddy_cultivated_area   "Paddy cultivated area, ha (논 금년경지합계면적)"
label variable nonpaddy_cultivated_area "Non-paddy cultivated area, ha (밭 금년경지합계면적)"
label variable total_cultivated_area   "Total cultivated area, ha (계 금년경지합계면적)"
label variable paddy_idle_area         "Paddy idle/fallow area, ha (논 규반합계면적)"
label variable nonpaddy_idle_area      "Non-paddy idle/fallow area, ha (밭 규반합계면적)"
label variable total_idle_area         "Total idle/fallow area, ha (계 규반합계면적)"
label variable paddy_arable_area       "Paddy arable area, ha (논 가경합계면적)"
label variable nonpaddy_arable_area    "Non-paddy arable area, ha (밭 가경합계면적)"
label variable total_arable_area       "Total arable area, ha (계 가경합계면적)"

* ── 4. LABEL VALUE: REGION CODE ─────────────────────────────────────────────
label define region_lbl ///
    11 "Seoul"          ///
    21 "Busan"          ///
    22 "Daegu"          ///
    23 "Incheon"        ///
    24 "Gwangju"        ///
    25 "Daejeon"        ///
    26 "Ulsan"          ///
    29 "Sejong"         ///
    31 "Gyeonggi"       ///
    32 "Gangwon"        ///
    33 "N.Chungcheong"  ///
    34 "S.Chungcheong"  ///
    35 "N.Jeolla"       ///
    36 "S.Jeolla"       ///
    37 "N.Gyeongsang"   ///
    38 "S.Gyeongsang"   ///
    39 "Jeju"
label values region_code region_lbl

* ── 5. PROFILE: MISSINGS AND NEGATIVES ───────────────────────────────────────
di _n "--- Profile: missing values ---"
foreach var of varlist paddy_cultivated_area-total_arable_area {
    qui count if missing(`var')
    di "`var': `r(N)' missing"
}

di _n "--- Profile: negative values ---"
foreach var of varlist paddy_cultivated_area-total_arable_area {
    qui count if `var' < 0 & !missing(`var')
    if r(N) > 0 {
        di "`var': `r(N)' negative values"
        list region_code `var' if `var' < 0, noobs
    }
}

* ── 6. ADD ANOMALY FLAG ──────────────────────────────────────────────────────
* Flag rows with any physically impossible (negative) area value.
* Affected: region_code=21 (Busan), paddy fields only.
gen data_anomaly_flag = 0
foreach var of varlist paddy_cultivated_area-total_arable_area {
    replace data_anomaly_flag = 1 if `var' < 0 & !missing(`var')
}
label variable data_anomaly_flag "=1 if row has physically impossible (negative) area values"
tab data_anomaly_flag, missing

* ── 7. RECODE NEGATIVES TO EXTENDED MISSING (.a) ─────────────────────────────
* Decision: negative land area is physically impossible — plausible entry error.
* Extended missing .a = "data anomaly / implausible value" in this project.
* Original raw CSV in data/clean/ is never modified.
* Three affected values: paddy_cultivated_area, paddy_idle_area,
*                        paddy_arable_area for region_code=21.
foreach var of varlist paddy_cultivated_area-total_arable_area {
    qui count if `var' < 0 & !missing(`var')
    if r(N) > 0 {
        di "Setting `r(N)' negative value(s) in `var' → .a"
        replace `var' = .a if `var' < 0
    }
}

* ── 8. ASSERT INTERNAL CONSISTENCY ──────────────────────────────────────────
* arable = cultivated − idle.
* Recast all area vars to double first: import delimited may store integer-
* looking columns as float (single precision, ~7 sig digits), which can
* produce rounding errors. Tolerance 1e-3 ha (~10 m²) is more than
* sufficient for provincial land area data.
recast double paddy_cultivated_area paddy_idle_area paddy_arable_area
recast double nonpaddy_cultivated_area nonpaddy_idle_area nonpaddy_arable_area
recast double total_cultivated_area total_idle_area total_arable_area

foreach prefix in "paddy" "nonpaddy" "total" {
    tempvar resid
    gen double `resid' = abs(`prefix'_cultivated_area ///
                           - `prefix'_idle_area        ///
                           - `prefix'_arable_area)     ///
        if !missing(`prefix'_cultivated_area,          ///
                    `prefix'_idle_area,                 ///
                    `prefix'_arable_area)
    qui sum `resid'
    * Tolerance 0.01 ha (100 m²): float rounding from CSV import produces
    * residuals ~0.003–0.006 ha. Python float64 verification shows true
    * consistency to 7e-12; the gap here is single-precision storage artifact.
    assert r(max) < 0.01
    di "Consistency OK: `prefix'_arable = cultivated − idle  (max |residual| = " %8.2e r(max) ")"
    drop `resid'
}

* ── 9. UNIQUENESS NOTE ───────────────────────────────────────────────────────
* (survey_year, region_code) does NOT uniquely identify observations:
* 9 rows per region code, no sub-identifier present in source data.
* This is a known issue — see CLEANING LOG below.
di _n "Rows per region_code:"
bysort region_code: gen _rn = _n
tab _rn
drop _rn

* ── 10. FINAL CHECKS ─────────────────────────────────────────────────────────
di _n "--- Final variable check ---"
describe
sum paddy_cultivated_area nonpaddy_cultivated_area total_cultivated_area, detail

* Verify no unlabeled variables remain
foreach var of varlist * {
    local lbl : variable label `var'
    if "`lbl'" == "" di "WARNING: `var' has no variable label"
}

* ── 11. SAVE ─────────────────────────────────────────────────────────────────
capture mkdir "data/clean"
save "data/clean/2021_cultivated_area_clean.dta", replace
di _n "Saved: data/clean/2021_cultivated_area_clean.dta  (N=`=_N', K=`=c(k)')"

* ── 12. CLEANING LOG ─────────────────────────────────────────────────────────
di _n "============================================================"
di    " CLEANING LOG — 2021 Korean Cultivated/Arable Land Area"
di    "============================================================"
di    " Source : data/temp/2021_cultivated_area_utf8.csv"
di    "          (EUC-KR → UTF-8 via encode_convert.py)"
di    " Output : data/clean/2021_cultivated_area_clean.dta"
di    " Script : scripts/stata/clean_2021_cultivated_area.do"
di    ""
di    " N in : 153 rows × 11 cols"
di    " N out: 153 rows × 12 cols  (+data_anomaly_flag)"
di    ""
di    " KEY DECISIONS"
di    " 1. Negative paddy values → extended missing .a"
di    "    Row: region_code=21 (Busan Metropolitan City)"
di    "    paddy_cultivated_area : -0.6152 → .a"
di    "    paddy_idle_area        : -0.0254 → .a"
di    "    paddy_arable_area      : -0.5898 → .a"
di    "    Rationale: negative land area is physically impossible."
di    "    Extended missing .a = 'data anomaly / implausible value'."
di    "    Original raw CSV is never modified (read-only)."
di    ""
di    " 2. All 12 variables labeled (English + Korean in label)."
di    " 3. region_code labeled with province/city names."
di    ""
di    " KNOWN ISSUES (unresolved)"
di    " 1. MISSING SUB-IDENTIFIER: 9 rows per province code."
di    "    (survey_year, region_code) does NOT uniquely identify obs."
di    "    The 9 rows likely represent sub-district or strata."
di    "    Do NOT run isid survey_year region_code — it will fail."
di    "    Clarification needed before merging or regression at obs level."
di    ""
di    " MERGE RATES: N/A (no merge performed)"
di    "============================================================"

log close
